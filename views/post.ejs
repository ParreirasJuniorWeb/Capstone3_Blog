<%- include("../views/header/header.ejs") %>

<main class="container mt-5">
  <div class="row g-5">
    <div class="col-md-8">
      <article class="blog-post">
        <strong class="d-inline-block mb-2 text-primary-emphasis"><%= post.label %></strong>
        <h1 class="display-5 mb-1"><%= post.title %></h1>
        <p class="blog-post-meta"><%= post.date %> por <a href="#"><%= post.writer %></a></p>
        <p class="lead"><%= post.subtitle %></p>
        <hr>
        
        <% post.article.forEach(paragrafo => { %>
            <p><%= paragrafo %></p>
        <% }) %>

      </article>

      <nav class="blog-pagination aria-label="Pagination">
        <a class="btn btn-outline-primary rounded-pill" href="/">Voltar para a Vitrine</a>
      </nav>
    </div>

    <div class="col-md-4">
      <div class="position-sticky" style="top: 2rem;">
        <div class="p-4 mb-3 bg-body-tertiary rounded">
          <h4 class="fst-italic">Sobre</h4>
          <p class="mb-0">Blog de Tecnologias, Saúde e Cultura só para você! Escolha o que quer lê!</p>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("../views/footer/footer.ejs") %>