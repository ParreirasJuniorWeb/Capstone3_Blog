<%- include("../views/header/header.ejs") %>

    <main class="container mt-5">
        <div
            class="p-4 p-md-5 mb-4 rounded text-body-emphasis bg-body-secondary d-flex justify-content-between align-items-center">
            <div>
                <h1 class="display-4 fst-italic">Painel Administrativo</h1>
                <p class="lead my-3">Gerencie as postagens da plataforma.</p>
            </div>
            <button class="btn btn-success btn-lg" data-bs-toggle="modal" data-bs-target="#modalCriar">Criar Novo
                Post</button>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Título</th>
                        <th>Categoria</th>
                        <th>Autor</th>
                        <th>Data</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% posts.forEach(post=> { %>
                        <tr>
                            <td><strong>
                                    <%= post.title %>
                                </strong></td>
                            <td><span class="badge rounded-pill bg-primary">
                                    <%= post.label %>
                                </span></td>
                            <td>
                                <%= post.writer %>
                            </td>
                            <td>
                                <%= post.date %>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                    data-bs-target="#editModal<%= post.id %>">Editar</button>

                                <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Deseja excluir permanentemente?')">Excluir</button>
                                </form>
                            </td>
                        </tr>

                        <div class="modal fade" id="editModal<%= post.id %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <form action="/posts/<%= post.id %>?_method=PUT" method="POST">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Editando: <%= post.title %>
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row g-3">
                                                <div class="col-12"><label class="form-label">Título</label><input
                                                        type="text" name="title" class="form-control"
                                                        value="<%= post.title %>" required></div>
                                                <div class="col-md-6"><label class="form-label">Categoria</label><input
                                                        type="text" name="label" class="form-control"
                                                        value="<%= post.label %>"></div>
                                                <div class="col-md-6"><label class="form-label">Autor</label><input
                                                        type="text" name="writer" class="form-control"
                                                        value="<%= post.writer %>" required></div>
                                                <div class="col-12"><label class="form-label">Conteúdo</label><textarea
                                                        name="article" class="form-control" rows="10"
                                                        required><%= post.article.join('\n\n') %></textarea></div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <div class="modal fade" id="modalCriar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form action="/posts" method="POST">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title">Nova Postagem</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3"><label class="form-label">Título</label><input type="text" name="title"
                                class="form-control" required></div>
                        <div class="mb-3"><label class="form-label">Subtítulo</label><input type="text" name="subtitle"
                                class="form-control"></div>
                        <div class="row">
                            <div class="col-md-6 mb-3"><label class="form-label">Categoria</label><input type="text"
                                    name="label" class="form-control"></div>
                            <div class="col-md-6 mb-3"><label class="form-label">Autor</label><input type="text"
                                    name="writer" class="form-control" required></div>
                        </div>
                        <div class="mb-3"><label class="form-label">Conteúdo</label><textarea name="article"
                                class="form-control" rows="6" required></textarea></div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">Publicar Agora</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include("../views/footer/footer.ejs") %>